# Copie para .env e preencha os valores.
# Na VM em produção: use NODE_ENV=production para que o log mostre "Ambiente: production".

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safs
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_SCHEMA=ctrl

# Servidor
PORT=5001
# Na VM/produção use production; em dev pode usar development
NODE_ENV=production

# JWT (troque por chaves seguras em produção)
JWT_SECRET=chave-secreta-jwt
JWT_REFRESH_SECRET=chave-secreta-refresh
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS: URL(s) do frontend, separadas por vírgula.
# Quando o frontend é servido pelo próprio backend (npm run build + abrir http://servidor:5001), use a mesma origem:
# FRONTEND_URL=http://10.28.0.124:5001
# Se o frontend rodar em outro host/porta (ex.: Vite na 5174):
# FRONTEND_URL=http://10.28.0.124:5174,http://localhost:5174
FRONTEND_URL=http://localhost:5174
